# Glean Agent API key (for schema fetches)
GLEAN_AGENT_API_KEY=your_agent_api_key_here
GLEAN_BACKEND=https://scio-prod-be.glean.com

# Glean Chat API key (CHAT scope — for agent execution, traces, and judge calls)
# Must have CHAT scope. Create at: Glean Settings > API > REST API tokens
GLEAN_CHAT_API_KEY=your_chat_api_key_here
GLEAN_INSTANCE=scio-prod

# Judge Models
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
