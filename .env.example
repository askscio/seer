# Glean Agent API (public - for agent execution fallback)
GLEAN_AGENT_API_KEY=your_agent_api_key_here
GLEAN_BACKEND=https://scio-prod-be.glean.com

# Glean Chat API (for judge/chat calls using TypeScript SDK)
GLEAN_CHAT_API_KEY=your_chat_api_key_here
GLEAN_INSTANCE=scio-prod

# Session Cookie (INTERNAL EMPLOYEES ONLY - for trace metadata)
# Extract from browser DevTools > Application > Cookies after SSO login
# Format: "cookie1=value1; cookie2=value2"
# This enables access to token counts, tool calls, and execution traces
# GLEAN_SESSION_COOKIE="<paste cookie string here>"

# Judge Models
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
