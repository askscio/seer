# Glean Agent API (for fetching schemas and running agents)
GLEAN_AGENT_API_KEY=your_agent_api_key_here
GLEAN_BACKEND=https://your-instance-be.glean.com

# Glean Chat API (for AI generation via judge/chat)
GLEAN_CHAT_API_KEY=your_chat_api_key_here
GLEAN_INSTANCE=your-instance-name

# Note: Copy this to .env.local and add your real keys
# The web UI shares the same API keys as the CLI
